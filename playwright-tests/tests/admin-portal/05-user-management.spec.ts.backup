    }
  });

  test('UM-057: Only view audit log by users module', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select Users
    await page.click('select[name="module"], .module-filter');
    await page.selectOption('select[name="module"], .module-filter', 'Users');
    await page.press('select[name="module"], .module-filter', 'Enter');
