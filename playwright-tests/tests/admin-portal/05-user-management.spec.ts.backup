    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator('text=Users')).toBeVisible();
    }
  });

  test('UM-058: Only view audit log by content management module', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select Content Management
    await page.click('select[name="module"], .module-filter');
    await page.selectOption('select[name="module"], .module-filter', 'Content Management');
    await page.press('select[name="module"], .module-filter', 'Enter');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for content management module is displayed
    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator('text=Content Management')).toBeVisible();
    }
  });

  test('UM-059: Only view audit log by settings module', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select Settings
    await page.click('select[name="module"], .module-filter');
    await page.selectOption('select[name="module"], .module-filter', 'Settings');
    await page.press('select[name="module"], .module-filter', 'Enter');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for settings module is displayed
    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator('text=Settings')).toBeVisible();
    }
  });

  test('UM-060: Only view audit log by certain users', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Username filter bar
    await page.click('select[name="username"], .username-filter');
    
    // Select a user
    await page.selectOption('select[name="username"], .username-filter', { index: 1 });
    const selectedUser = await page.locator('select[name="username"] option:checked').textContent();
    
    // Click enter
    await page.press('select[name="username"], .username-filter', 'Enter');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for the selected user is displayed
    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator(`text=${selectedUser}`)).toBeVisible();
    }
  });

  test('UM-061: Only view audit log from certain period of time', async ({ page }) => {
    // Module: Audit Log Page
    // Click the date filter
    const startDate = new Date();
    startDate.setDate(startDate.getDate() - 7);
    const endDate = new Date();
    
    await page.fill('input[name="startDate"], input[type="date"]', startDate.toISOString().split('T')[0]);
    await page.fill('input[name="endDate"], input[type="date"]', endDate.toISOString().split('T')[0]);
    
    // Click enter or apply filter
    await page.click('button:has-text("Apply"), button:has-text("Filter")');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for the selected time period is displayed
    const logCount = await page.locator('table tbody tr').count();
    expect(logCount).toBeGreaterThanOrEqual(0);
  });

  test('UM-062: View audit log for single module and single user', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select a module
    await page.click('select[name="module"], .module-filter');
    await page.selectOption('select[name="module"], .module-filter', 'Order');
    await page.press('select[name="module"], .module-filter', 'Enter');
    
    // Click the dropdown in Username filter bar and select a user
    await page.click('select[name="username"], .username-filter');
    await page.selectOption('select[name="username"], .username-filter', { index: 1 });
    const selectedUser = await page.locator('select[name="username"] option:checked').textContent();
    await page.press('select[name="username"], .username-filter', 'Enter');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for the selected module and user is displayed
    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator('text=Order')).toBeVisible();
      await expect(row.locator(`text=${selectedUser}`)).toBeVisible();
    }
  });

  test('UM-063: View audit log for multiple modules and multiple users', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select 2+ modules
    await page.click('select[name="module"], .module-filter[multiple]');
    await page.selectOption('select[name="module"], .module-filter[multiple]', ['Order', 'Voucher']);
    
    // Click the dropdown in Username filter bar and select 2+ users
    await page.click('select[name="username"], .username-filter[multiple]');
    await page.selectOption('select[name="username"], .username-filter[multiple]', [{ index: 1 }, { index: 2 }]);
    
    // Apply filter
    await page.click('button:has-text("Apply"), button:has-text("Filter")');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for the selected modules and users is displayed
    const logCount = await page.locator('table tbody tr').count();
    expect(logCount).toBeGreaterThanOrEqual(0);
  });

  test('UM-064: View audit log for single module made by single user in certain time range', async ({ page }) => {
    // Module: Audit Log Page
    // Click the dropdown in Module filter bar and select a module
    await page.click('select[name="module"], .module-filter');
    await page.selectOption('select[name="module"], .module-filter', 'Order');
    
    // Click the dropdown in Username filter bar and select a user
    await page.click('select[name="username"], .username-filter');
    await page.selectOption('select[name="username"], .username-filter', { index: 1 });
    const selectedUser = await page.locator('select[name="username"] option:checked').textContent();
    
    // Click the dropdown in Date filter bar and select time range
    const startDate = new Date();
    startDate.setDate(startDate.getDate() - 7);
    const endDate = new Date();
    
    await page.fill('input[name="startDate"], input[type="date"]', startDate.toISOString().split('T')[0]);
    await page.fill('input[name="endDate"], input[type="date"]', endDate.toISOString().split('T')[0]);
    
    // Click enter or apply filter
    await page.click('button:has-text("Apply"), button:has-text("Filter")');
    await page.waitForTimeout(1000);
    
    // Expected Result: All audit logs for the selected module and user made at a certain time range is displayed
    const rows = await page.locator('table tbody tr').all();
    for (const row of rows) {
      await expect(row.locator('text=Order')).toBeVisible();
      await expect(row.locator(`text=${selectedUser}`)).toBeVisible();
    }
  });
});
