{
  "loginPage": {
    "usernameInput": "input[name=\"username\"]",
    "passwordInput": "input[name=\"password\"]",
    "signInButton": "button[type=\"submit\"]",
    "forgotPasswordButton": "button:has-text(\"Forgot password\")"
  },
  "resetPasswordPage": {
    "usernameInput": "input[name=\"username\"]",
    "verificationCodeInput": "input[name=\"verificationCode\"]",
    "passwordInput": "input[name=\"password\"]",
    "confirmPasswordInput": "input[name=\"confirmPassword\"]",
    "submitButton": "button[type=\"submit\"]",
    "resendButton": "button:has-text(\"Resend Code\")",
    "backToLoginButton": "button:has-text(\"Back to Login\")"
  },
  "validationMessages": {
    "passwordRequirement": "text=Password must include 1 number, 1 uppercase letter & 1 symbol",
    "passwordMismatch": "text=Password must match",
    "invalidCode": "text=Invalid verification code",
    "passwordReused": "text=Password has previously been used",
    "successMessage": "text=Success",
    "resendSuccess": "text=Validation code has been sent"
  },
  "urls": {
    "login": "https://corpvoucher.fam-stg.click/admin/login",
    "resetPassword": "https://corpvoucher.fam-stg.click/admin/reset-password"
  }
}
