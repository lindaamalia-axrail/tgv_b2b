{
  "name": "tgv-corporate-voucher-tests",
  "version": "1.0.0",
  "description": "Automated test suite for TGV Corporate Voucher platform",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:admin": "playwright test tests/admin-portal/",
    "test:public": "playwright test tests/public-web/",
    "test:report": "playwright show-report",
    "test:open": "playwright test && playwright show-report",
    "test:public:open": "playwright test tests/public-web/ && playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
